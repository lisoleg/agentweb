# =============== Environment Configuration ===============
# Node Environment
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# =============== Database Configuration ===============
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://agentweb:agentweb_secure_password@localhost:5432/agentweb?schema=public"

# Database credentials (used by docker-compose)
DB_USER=agentweb
DB_PASSWORD=agentweb_secure_password
DB_NAME=agentweb
DB_PORT=5432
DB_HOST=localhost

# =============== Redis Configuration ===============
REDIS_URL="redis://:redis_secure_password@localhost:6379"
REDIS_PASSWORD=redis_secure_password
REDIS_PORT=6379
REDIS_HOST=localhost

# =============== JWT Configuration ===============
# JWT secret key - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============== DID Configuration ===============
# DID method name
DID_METHOD=agentweb
# IPFS gateway for DID documents (optional)
IPFS_GATEWAY=https://ipfs.io/ipfs/

# =============== Blockchain Configuration ===============
# Ethereum L2 RPC URL (Optimism Goerli for test, mainnet for production)
ETH_RPC_URL=https://goerli.optimism.io
# Contract addresses (set after deployment)
AGENT_REGISTRY_ADDRESS=
PHI_STAKING_ADDRESS=
GOVERNANCE_ADDRESS=
PHI_TOKEN_ADDRESS=

# Private key for contract operations (KEEP SECURE!)
# Format: 0x... (with 0x prefix)
ETH_PRIVATE_KEY=0x_your_private_key_here

# =============== BSV Configuration ===============
# BSV network (mainnet or testnet)
BSV_NETWORK=testnet
# BSV wallet mnemonic (KEEP SECURE!)
BSV_MNEMONIC=your twelve word mnemonic phrase here
# BSV Paymail for payments
BSV_PAYMAIL=

# =============== Phi Engine Configuration ===============
# Phi Engine URL (Python FastAPI service)
PHI_ENGINE_URL=http://localhost:8000
PHI_ENGINE_PORT=8000
# Phi calculation parameters
PHI_DECAY_RATE=0.95
PHI_MIN_VALUE=0.0
PHI_MAX_VALUE=1.0

# =============== Frontend Configuration ===============
# API URL for frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_PORT=5173

# =============== Logging Configuration ===============
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=14d

# =============== CORS Configuration ===============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============== Rate Limiting ===============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============== Security ===============
# Enable/disable security headers
ENABLE_HELMET=true
# Cookie secret for sessions
COOKIE_SECRET=your-cookie-secret-change-in-production

# =============== Blockchain Contract Configuration ===============
# Gas settings
GAS_PRICE_GWEI=1
GAS_LIMIT=3000000

# =============== Features ===============
# Enable/disable features
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_P2P=false
